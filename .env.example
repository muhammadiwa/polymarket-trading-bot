# ── Infrastructure ────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=pqap
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pqap
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# NATS
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222

# ── Authentication ────────────────────────────────────────────────

# JWT secret (required — all services refuse to start if empty)
JWT_SECRET=changeme-use-a-real-secret

# ── API Gateway ──────────────────────────────────────────────────

API_GATEWAY_PORT=8080
CORS_ORIGINS=http://localhost:3000

# ── Service Ports ────────────────────────────────────────────────

ANALYTICS_PORT=8084
BACKTESTING_PORT=8085
AI_OPTIMIZER_PORT=8086
AI_ASSISTANT_PORT=8087
STRATEGY_MANAGER_PORT=8088
PORTFOLIO_MANAGER_PORT=8089
NOTIFICATION_PORT=8090
ACCOUNT_MANAGER_PORT=8091
DASHBOARD_PORT=3000

# ── Go Services (external, not in compose) ──────────────────────

SCANNER_URL=http://localhost:8091
ARB_ENGINE_URL=http://localhost:8092
EXECUTION_ENGINE_URL=http://localhost:8093
POSITION_MANAGER_URL=http://localhost:8095
RISK_MANAGER_URL=http://localhost:8094

# ── Analytics ────────────────────────────────────────────────────

ANALYTICS_LOG_LEVEL=info
ANALYTICS_RISK_FREE_RATE=0

# Anomaly detection
ANOMALY_WIN_RATE_DROP=0.20
ANOMALY_DRAWDOWN_MULTIPLIER=2.0
ANOMALY_CONSECUTIVE_LOSSES=5
ANOMALY_PROFIT_FACTOR_LOW=0.5
ANOMALY_SHARPE_LOW=0
ANOMALY_CHECK_INTERVAL_SECONDS=3600

# ── Strategy Manager ────────────────────────────────────────────

STRATEGY_LOG_LEVEL=info

# ── AI ───────────────────────────────────────────────────────────

# OpenAI-compatible API key for AI assistant / optimizer
OPENAI_API_KEY=

# ── Notification ─────────────────────────────────────────────────

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Risk Defaults ────────────────────────────────────────────────

DEFAULT_DAILY_LOSS_LIMIT_PCT=2.0
DEFAULT_MAX_POSITION_PER_MARKET_PCT=10.0
DEFAULT_MAX_POSITION_PER_STRATEGY_PCT=20.0
DEFAULT_DRAWDOWN_THRESHOLD_PCT=10.0

# ── Logging ──────────────────────────────────────────────────────

LOG_LEVEL=info
